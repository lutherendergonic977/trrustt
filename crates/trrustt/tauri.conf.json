{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/crates/tauri-config-schema/schema.json",
  "productName": "TRRUSTT",
  "version": "0.1.0",
  "identifier": "dev.trrustt.builder",
  "build": {
    "beforeDevCommand": "cd frontend && pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && pnpm build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "title": "🔷 trRUSTt",
    "windows": [
      {
        "title": "🔷 trRUSTt — AI-driven Power BI External Tool",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
